{
  "name": "@rhf-webmcp/core",
  "version": "0.1.0",
  "description": "React Hook Form を1行追加でWebMCP対応にするライブラリ（コアパッケージ）",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-hook-form": ">=7.0.0"
  },
  "license": "MIT"
}
